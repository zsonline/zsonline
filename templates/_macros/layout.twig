{% macro header(args) %}
    {% set args = {
        siteName: siteName,
        siteUrl: siteUrl,
        size: 'small',
        style: 'solid'
    } | merge(args) %}

    {% from '_macros/button.twig' import button, link %}
    {% from '_macros/icon.twig' import icon %}

    <header class="{{ html_classes(
        'header',
        'header--' ~ args.size,
        'header--scroll-top',
        {
            'header--gradient': args.style == 'gradient',
            'header--transparent': args.style == 'transparent'
        }
    ) }}">
        <div class="header__inner">
            <a class="header__logo" href="{{ args.siteUrl }}">
                <h1>{{ args.siteName }}</h1>
                {{ svg('@templates/_svgs/logo.svg') | attr({ 'class': 'logo' }) }}
                {{ svg('@templates/_svgs/icon.svg') | attr({ 'class': 'icon' }) }}
            </a>

            <nav class="header__navigation-top">
                {{ link({
                    href: url('suche'),
                    icon: 'search',
                    label: 'Suche',
                    responsive: true,
                    style: 'bright'
                }) }}
                {{ button({
                    icon: 'menu',
                    label: 'Menü',
                    onclick: 'ZS.Navigation.Main.open();',
                    responsive: true,
                    style: 'bright'
                }) }}
            </nav>
        </div>

        <div class="header__rule">
            <div class="header__rule__progress progress"></div>
        </div>

        <nav id="header__navigation-main" class="header__navigation-main">
            {{ button({
                icon: 'x',
                label: 'Schliessen',
                onclick: 'ZS.Navigation.Main.close();',
                style: 'dark'
            }) }}

            <div class="header__navigation-main__component">
                {{ _self.navigation() }}
            </div>

            <div class="header__socials">
                <span>Folge uns:</span>
                {{ _self.socials({
                    orientation: 'vertical'
                }) }}
            </div>
        </nav>

        <div id="header__navigation-main__overlay" class="header__navigation-main__overlay" onclick="ZS.Navigation.Main.close();"></div>
    </header>
{% endmacro %}

{% macro footer() %}
    {% from '_macros/button.twig' import link %}

    <footer class="footer">
        <div class="footer__inner">
            <div class="footer__bottom">
                <div class="footer__about">
                    {{ svg('@templates/_svgs/logo.svg') | attr({ 'class': 'footer__logo' }) }}

                    <b>Zürcher Studierendenzeitung</b><br>
                    <span>Die unabhängige Zeitung für Universität Zürich und ETH Zürich. Seit 1923.</span>
                </div>

                {{ _self.socials({
                    orientation: 'horizontal'
                }) }}

                <div class="footer__source">
                    Quellcode:
                    {{ link({
                        href: 'https://github.com/zsonline',
                        label: 'Github',
                        target: '_blank'
                    }) }}
                </div>
            </div>
        </div>
    </footer>
{% endmacro %}

{% macro navigation() %}
    {% from '_macros/icon.twig' import icon %}

    {% set recentArticles = craft.entries()
        .section('articles')
        .after(now|date_modify("-6 months")|atom)
        .orderBy('postDate DESC')
        .collect() %}

    {% set topics = craft.entries()
        .section('topics')
        .relatedTo({ sourceElement: recentArticles, field: 'articleTopics' })
        .limit(5)
        .collect() %}

    {% set formats = craft.entries()
        .section('formats')
        .relatedTo({ sourceElement: recentArticles, field: 'articleFormat' })
        .limit(5)
        .collect() %}

    {% set issues = craft.entries()
        .section('issues')
        .orderBy('issueYear DESC, issueNumber DESC')
        .limit(3)
        .collect() %}

    {% set navigation = craft.entries()
        .section('navigation')
        .with(['navigationSections.navigationSection:navigationSectionItems'])
        .limit(1)
        .collect()
        .first() %}

    {% set additionalSections = [] %}
    {% if navigation %}
        {% for section in navigation.navigationSections.all() %}
            {% set items = section.navigationSectionItems.all() %}
            {% set primaryItem = items|first %}
            {% if primaryItem %}
                {% set children = [] %}
                {% for item in items|slice(1) %}
                    {% if item.navigationSectionItemLink %}
                        {% set children = children|merge([{
                            title: item.navigationSectionItemLink.label,
                            url: item.navigationSectionItemLink.url
                        }]) %}
                    {% endif %}
                {% endfor %}
                {% set additionalSections = additionalSections|merge([{
                    title: primaryItem.navigationSectionItemLink.label,
                    url: primaryItem.navigationSectionItemLink.url,
                    children: children
                }]) %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% set sections = [
        { title: 'Neuste Artikel', url: url('artikel'), children: [] },
        { title: 'Themen', url: url('themen'), children: topics },
        { title: 'Rubriken', url: url('rubriken'), children: formats },
        { title: 'Print-Archiv', url: url('print'), children: issues },
        { title: 'Abonnieren', url: url('abonnieren'), children: [] }
    ]|merge(additionalSections) %}

    <ul class="navigation">
        {% for section in sections %}
            <li class="navigation__section">
                <div class="navigation__item navigation__item--primary">
                    <a href="{{ section.url }}">{{ section.title }}</a>
                    {% if section.children|length > 0 %}
                        <button onclick="ZS.Navigation.toggleSection(this)">{{ icon({ name: 'chevron-down' }) }}</button>
                    {% endif %}
                </div>

                {% if section.children|length > 0 %}
                    <ul class="navigation__subsection">
                        {% for child in section.children %}
                            <li>
                                <div class="navigation__item navigation__item--secondary">
                                    <a href="{{ child.url }}">{{ child.title }}</a>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </li>
        {% endfor %}
    </ul>
{% endmacro %}

{% macro socials(args) %}
    {% set args = {
        class: '',
        orientation: 'horizontal'
    } | merge(args) %}

    {% from '_macros/button.twig' import link %}

    <ul class="{{ html_classes('socials', 'socials--' ~ args.orientation, args.class) }}">
        <li>
            {{ link({
                href: 'https://www.instagram.com/zs__online/',
                icon: 'instagram',
                label: 'Instagram',
                target: '_blank'
            }) }}
        </li>
        <li>
            {{ link({
                href: 'https://twitter.com/zsonline/',
                icon: 'twitter',
                label: 'Twitter',
                target: '_blank'
            }) }}
        </li>
        <li>
            {{ link({
                href: 'https://www.facebook.com/medienvereinZS/',
                icon: 'facebook',
                label: 'Facebook',
                target: '_blank'
            }) }}
        </li>
    </ul>
{% endmacro %}
